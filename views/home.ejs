<%- include("includes/navbar.ejs") %>
<link rel="stylesheet" href="/homeStyle.css" />
<body>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <div id="hero" class="relative h-screen overflow-hidden pt-16">
      <!-- Parallax background image -->
      <div
        id="hero-image"
        class="absolute inset-0 h-[120%] w-full"
        style="
          background-image: url('https://images.pexels.com/photos/8945172/pexels-photo-8945172.jpeg');
          background-size: cover;
          background-position: center;
          transform: translateY(0);
        "
      ></div>

      <!-- Overlay for better text readability -->
      <div class="absolute inset-0 bg-black/40"></div>

      <!-- Animation overlay -->
      <div id="hero-overlay" class="absolute inset-0 bg-black z-10"></div>

      <!-- Hero content -->
      <div
        id="hero-text"
        class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4"
      >
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight"
        >
          REDEFINE YOUR STYLE
        </h1>
        <p class="text-xl md:text-2xl text-white/90 max-w-3xl mb-8">
          Innovative designs that push boundaries. Sustainable fashion that
          makes a statement.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <form
            action="/api/newArrival"
            method="get"
            class="inline-flex h-12 items-center justify-center rounded-md bg-white px-8 text-sm font-medium text-black shadow transition-colors hover:bg-white/90"
          >
            <button>SHOP NEW ARRIVALS</button>
          </form>
          <form
            action="/api/collection"
            method="get"
            class="inline-flex h-12 items-center justify-center rounded-md border border-white bg-transparent px-8 text-sm font-medium text-white shadow-sm transition-colors hover:bg-white/10"
          >
            <button>EXPLORE COLLECTIONS</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Products Section -->
    <section id="products-section" class="py-24 bg-background">
      <div class="container px-4 md:px-6">
        <a href="collection.html" class="relative">
          <h2
            id="section-title"
            class="text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl text-center mb-12 opacity-0 transform translate-y-10"
          >
            Latest Collection
          </h2>
        </a>
        <div
          id="products-grid"
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8"
        >
          <!-- Products will be added here dynamically -->
          <% products.forEach(product => { %>
          <div class="product-card">
            <div
              class="aspect-[3/4] w-full bg-muted overflow-hidden rounded-lg"
            >
              <img
                src="<%= product.image %>"
                alt="<%= product.name %>"
                class="product-image h-full w-full object-cover"
              />
            </div>
            <div class="product-details mt-2">
              <h3 class="font-medium text-lg"><%= product.name %></h3>
              <p class="text-sm">$<%= product.price %></p>
              <button
                class="mt-2 bg-primary text-primary-foreground px-4 py-2 rounded-md text-sm hover:bg-primary/90 transition-colors"
              >
                Add to Cart
              </button>
            </div>
          </div>
          <% }) %>
        </div>

        <div class="flex justify-center mt-12">
          <form
            action="/api/collection"
            method="get"
            class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-8 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 transform hover:scale-105 active:scale-95"
          >
            <button>View all Collections</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <%- include("includes/footer.ejs") %>
  <script src="/script.js"></script>
</body>
