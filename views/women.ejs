<%- include("includes/navbar.ejs") %>

<main>
  <div class="container mx-auto px-4 py-16" id="page-content">
    <h1 class="text-4xl font-bold mb-12 text-center">Women's Collection</h1>

    <div class="grid md:grid-cols-3 gap-8">
      <div
        class="product-card reveal-section bg-white shadow-lg rounded-lg overflow-hidden transform transition-transform hover:scale-105"
      >
        <img
          src="/d1.jpg"
          alt="Double-breasted waistcoat"
          class="w-full object-cover"
        />
        <div class="product-info p-6">
          <h2 class="text-2xl font-bold mb-2">Double-breasted waistcoat</h2>
          <p class="price text-gray-600">$59.99</p>
        </div>
      </div>

      <div
        class="product-card reveal-section bg-white shadow-lg rounded-lg overflow-hidden transform transition-transform hover:scale-105"
      >
        <img
          src="/d2.jpg"
          alt="Oversized crinkled dress"
          class="w-full object-cover"
        />
        <div class="product-info p-6">
          <h2 class="text-2xl font-bold mb-2">Oversized crinkled dress</h2>
          <p class="price text-gray-600">$79.99</p>
        </div>
      </div>

      <div
        class="product-card reveal-section bg-white shadow-lg rounded-lg overflow-hidden transform transition-transform hover:scale-105"
      >
        <img
          src="/b1.jpg"
          alt="Napped sock boots"
          class="w-full object-cover"
        />
        <div class="product-info p-6">
          <h2 class="text-2xl font-bold mb-2">Napped sock boots</h2>
          <p class="price text-gray-600">$109.99</p>
        </div>
      </div>
    </div>
  </div>
</main>


