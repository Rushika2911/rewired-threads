<%- include("includes/navbar.ejs") %>

<main>
  <div class="container mx-auto px-4 py-16" id="page-content">
    <h1 class="text-4xl font-bold mb-12 text-center">About Rewired Threads</h1>

    <div class="max-w-4xl mx-auto">
      <div class="reveal-section mb-12">
        <img
          src="/m1.jpg"
          alt="Rewired Threads Studio"
          class="w-full rounded-lg shadow-lg"
        />
      </div>

      <div class="space-y-6">
        <div class="reveal-section">
          <h2 class="text-2xl font-semibold mb-4">Our Vision</h2>
          <p>
            Rewired Threads is more than a clothing brand. We're a fusion of
            technology, design, and urban culture, creating apparel that speaks
            to the digital generation.
          </p>
        </div>

        <div class="reveal-section">
          <h2 class="text-2xl font-semibold mb-4">Sustainable Innovation</h2>
          <p>
            We're committed to sustainable practices, using recycled materials
            and cutting-edge manufacturing techniques to minimize our
            environmental impact.
          </p>
        </div>
      </div>
    </div>
  </div>
</main>

